{
  "name": "shadcn-ui-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "node ./scripts/clean-workspace.mjs",
    "clean:dry": "node ./scripts/clean-workspace.mjs --dry-run",
    "dev:learnings": "turbo dev --filter=learnings",
    "build:learnings": "turbo build --filter=learnings",
    "start:learnings": "pnpm --filter=learnings start",
    "dev:portfolio": "turbo dev --filter=portfolio",
    "build:portfolio": "turbo build --filter=portfolio",
    "start:portfolio": "pnpm --filter=portfolio start"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  }
}
